# All pages — send full URL as referrer (needed for Google Maps API key domain restrictions)
/*
  Referrer-Policy: no-referrer-when-downgrade

# index.html — never cache at edge or browser
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

# service-worker — must always be fresh
/service-worker.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# manifest
/manifest.json
  Cache-Control: no-cache, no-store, must-revalidate

# JS bundles — content-hashed, safe to cache forever
/_expo/static/js/web/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts — content-hashed, safe to cache forever
/fonts/*.ttf
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/ttf
  Access-Control-Allow-Origin: *

/assets/*.ttf
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/ttf
  Access-Control-Allow-Origin: *

/_expo/static/media/*.ttf
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/ttf
  Access-Control-Allow-Origin: *
